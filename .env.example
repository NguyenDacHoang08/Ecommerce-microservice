# ─── Root .env.example ───────────────────
# Copy to .env and fill in values

# MySQL (user-service)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=user_svc
MYSQL_PASSWORD=user_pass

# PostgreSQL passwords
POSTGRES_USER=svc_user
POSTGRES_PRODUCT_PASSWORD=product_pass
POSTGRES_CART_PASSWORD=cart_pass
POSTGRES_ORDER_PASSWORD=order_pass
POSTGRES_PAYMENT_PASSWORD=payment_pass
POSTGRES_SHIPPING_PASSWORD=shipping_pass

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
