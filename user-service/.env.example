# ─── user-service environment ───────────
DEBUG=False
SECRET_KEY=change-me-in-production-use-50-chars

# MySQL (User service uses MySQL)
DATABASE_URL=mysql://user_svc:user_pass@mysql:3306/user_db

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_SIGNING_KEY=change-me-jwt-secret

# CORS
CORS_ALLOWED_ORIGINS=http://localhost,http://gateway

# RabbitMQ
CELERY_BROKER_URL=amqp://admin:admin@rabbitmq:5672/

# Service-to-service (internal)
SERVICE_SECRET_KEY=internal-service-secret
ALLOWED_HOSTS=user-service,localhost,127.0.0.1
